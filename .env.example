# Tallinna Õpilasmalev — Kandidaadi andmed
# ==========================================
# JUHEND:
#   1. Kopeeri see fail nimega .env:  cp .env.example .env
#   2. Täida .env oma päris andmetega
#   3. NB! .env faili ÄRGE GitHubi laadige — see on privaatne!
#
# .gitignore kaitseb sind automaatselt — .env ei lähe reposse.

# Õpilase andmed
NIMI=Õpilase täisnimi
ISIKUKOOD=XXXXXXXXXXX
AADRESS=Tänav number, Linn, Maakond
TELEFON=+372XXXXXXXX
EMAIL=opilane@email.ee

# Lapsevanema andmed
LAPSEVANEMA_TELEFON=+372XXXXXXXX
LAPSEVANEMA_EMAIL=lapsevanem@email.ee

# Kooli andmed
KOOL=Kooli täisnimi

# Pangaandmed
PANGAKONTO=EEXX XXXX XXXX XXXX XXXX
PANGAKONTO_OMANIK=Konto omaniku täisnimi

# Vormi valikud
SARGI_SUURUS=M

# Pikemad tekstivastused (kirjuta ühele reale)
HUVIALAD=Kirjelda oma huvialasid siia ühel real...
MALEVAKOGEMUS=Kirjelda oma varasemaid töökogemusi siia ühel real...
MOTIVATSIOON=Põhjenda miks soovid malevas osaleda siia ühel real...

# Rühma eelistused
RYHM_1=Eelistatud rühm (1. valik)
RYHM_2=Eelistatud rühm (2. valik)
